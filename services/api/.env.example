# Server
PORT=5000
NODE_ENV=development

# Database
DATABASE_URL="postgresql://ledgerlift:password@localhost:5432/ledgerlift"

# JWT
JWT_SECRET=your-jwt-secret-minimum-32-characters
JWT_EXPIRATION=24h

# CORS
CORS_ORIGIN=http://localhost:3000

# APIs (to be provided by Monark)
PINAX_API_KEY=your-pinax-api-key
COINGECKO_API_KEY=your-coingecko-api-key

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=info